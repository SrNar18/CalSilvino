{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Live Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Live Reload (npx live-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=5500", "--no-browser"],
      "port": 5500
    }
  ]
}
